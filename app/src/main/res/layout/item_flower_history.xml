<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    android:background="@drawable/card_background"
    android:gravity="center_vertical">

    <com.example.flowerfocus.utils.FlowerView
        android:id="@+id/itemFlowerView"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginEnd="16dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/itemCategoryText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Travail"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/on_surface" />

            <TextView
                android:id="@+id/itemStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Terminée"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant" />
        </LinearLayout>

        <TextView
            android:id="@+id/itemDateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01/01/2024 10:00"
            android:textSize="12sp"
            android:textColor="@color/on_surface_variant"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/itemDurationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25 min"
            android:textSize="13sp"
            android:textColor="@color/primary" />

    </LinearLayout>
</LinearLayout>
